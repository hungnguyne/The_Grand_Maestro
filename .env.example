# THE GRAND MAESTRO - Environment Configuration
# Copy this file to .env and fill in your keys.

# 1. Gemini API Key (Required for the default "Maestro" brain)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. App URL (Optional, used for deployment references)
APP_URL=http://localhost:3000

# NOTE: This app also supports adding OpenAI and OpenRouter keys 
# directly through the "API Settings" menu in the user interface.
# Those keys are stored securely in your browser's LocalStorage.
